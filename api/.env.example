# Portal's own Supabase (tenant registry)
SUPABASE_DB_URL=postgresql://postgres:[password]@[host]:5432/postgres
DB_SSLMODE=require

# Agency-hub API
AGENCY_API_URL=https://agency-hub.yourdomain.com
PORTAL_ADMIN_SECRET=<shared secret — must match PORTAL_ADMIN_SECRET in agency-hub>

# Auth
JWT_SECRET=<random 64+ chars>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Redis — Upstash connection string (token is embedded in the URL)
# Format: rediss://default:<token>@<host>.upstash.io:6379
UPSTASH_REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5-20251001
CLAUDE_DEFAULT_MONTHLY_TOKEN_BUDGET=150000

# Email — set MAILER_PROVIDER to "resend" or "brevo"
MAILER_PROVIDER=resend
EMAIL_FROM=noreply@youragency.com
# Resend (required when MAILER_PROVIDER=resend):
RESEND_API_KEY=re_...
# Brevo (required when MAILER_PROVIDER=brevo):
# BREVO_SMTP_USER=
# BREVO_SMTP_KEY=

# App
ENVIRONMENT=production
PUBLIC_URL=https://your-railway-backend.up.railway.app
FRONTEND_URL=https://your-vercel-frontend.vercel.app
PORT=8081
